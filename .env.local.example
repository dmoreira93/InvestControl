# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# Opcional: usado apenas se você precisar de operações server-side com privilégios
# elevados (ex: jobs administrativos). NUNCA exponha esta chave no client.
# SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui
